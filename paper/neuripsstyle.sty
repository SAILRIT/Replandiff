%% neuripsstyle.sty -- layout-compatible reimplementation of the NeurIPS
%% single-column style: 5.5in x 9in text block, 10pt Times, 17pt title.
%%
%% THIS IS NOT THE OFFICIAL NeurIPS FILE. It reproduces the layout so the paper
%% compiles anywhere. For submission, download the official workshop style file
%% and replace `\usepackage[preprint]{neuripsstyle}` with `\usepackage{neurips_XXXX}`
%% -- no changes to the document body are needed.
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{neuripsstyle}[2026/07/17 NeurIPS-compatible layout]

\newif\if@nipslines \@nipslinesfalse
\DeclareOption{preprint}{\@nipslinesfalse}
\DeclareOption{final}{\@nipslinesfalse}
\DeclareOption{submission}{\@nipslinestrue}
\ProcessOptions\relax

\RequirePackage[letterpaper,left=1.5in,right=1.5in,top=1in,bottom=1in]{geometry}
\RequirePackage{mathptmx}
\RequirePackage{lineno}
\if@nipslines \linenumbers \fi

% ---- title block -------------------------------------------------------------
\def\@noticestring{}
\newcommand{\noticeline}[1]{\gdef\@noticestring{#1}}
\newcommand\blfootnote[1]{\begingroup\renewcommand\thefootnote{}\footnote{#1}%
  \addtocounter{footnote}{-1}\endgroup}
\renewcommand{\maketitle}{%
  \par\begingroup
  \centering
  {\fontsize{17}{20}\selectfont\bfseries\@title\par}
  \vskip 0.9em
  {\normalsize\@author\par}
  \endgroup
  \vskip 1.4em
  \ifx\@noticestring\@empty\else\blfootnote{\@noticestring}\fi
  \thispagestyle{empty}\pagestyle{plain}
}

% ---- abstract ----------------------------------------------------------------
\renewenvironment{abstract}{%
  \vskip 0.1in
  \centerline{\large\bfseries Abstract}
  \vspace{0.6ex}
  \begin{quote}\small
}{\par\end{quote}\vskip 0.12in}

% ---- headings ----------------------------------------------------------------
\renewcommand\section{\@startsection{section}{1}{\z@}%
  {-2.0ex \@plus -0.5ex \@minus -0.2ex}{1.1ex \@plus 0.3ex}%
  {\normalfont\large\bfseries}}
\renewcommand\subsection{\@startsection{subsection}{2}{\z@}%
  {-1.6ex \@plus -0.4ex \@minus -0.2ex}{0.8ex \@plus 0.2ex}%
  {\normalfont\normalsize\bfseries}}
\renewcommand\paragraph{\@startsection{paragraph}{4}{\z@}%
  {1.2ex \@plus 0.3ex \@minus 0.2ex}{-0.6em}{\normalfont\normalsize\bfseries}}

% ---- float spacing (NeurIPS-like tightness) -----------------------------------
\setlength{\textfloatsep}{0.22in \@plus 2pt \@minus 2pt}
\setlength{\floatsep}{0.18in \@plus 2pt \@minus 2pt}
\setlength{\intextsep}{0.18in \@plus 2pt \@minus 2pt}
\setlength{\abovecaptionskip}{5pt}
\setlength{\belowcaptionskip}{0pt}
\setlength{\parskip}{0pt}
\renewcommand{\topfraction}{0.95}
\renewcommand{\bottomfraction}{0.9}
\renewcommand{\textfraction}{0.05}
\renewcommand{\floatpagefraction}{0.85}
